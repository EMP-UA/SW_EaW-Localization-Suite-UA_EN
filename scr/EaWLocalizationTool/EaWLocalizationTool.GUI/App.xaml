<Application x:Class="EaWLocalizationTool.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ═══════════════════════════════════════════════════════════════════
             КОЛЬОРИ (початкові — EMP_UA Dark, оновлюються ThemeManager)
             COLORS  (initial — EMP_UA Dark, updated by ThemeManager)
             ═══════════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BgBase"      Color="#0D0A14"/>
        <SolidColorBrush x:Key="BgSurface"   Color="#130F1E"/>
        <SolidColorBrush x:Key="BgCard"      Color="#1C1530"/>
        <SolidColorBrush x:Key="BgCardHov"   Color="#25203F"/>
        <SolidColorBrush x:Key="BdNorm"      Color="#2E1F5E"/>
        <SolidColorBrush x:Key="BdAcc"       Color="#4A2F8A"/>
        <SolidColorBrush x:Key="TextPrim"    Color="#EAE0FF"/>
        <SolidColorBrush x:Key="TextSec"     Color="#B0A0D0"/>
        <SolidColorBrush x:Key="TextDim"     Color="#7A60A8"/>
        <SolidColorBrush x:Key="Accent"      Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AccentDark"  Color="#6D3AD9"/>
        <SolidColorBrush x:Key="FlagYellow"  Color="#F5C518"/>
        <SolidColorBrush x:Key="FlagBlue"    Color="#0057B8"/>
        <SolidColorBrush x:Key="StatusGreen" Color="#2ECC71"/>
        <SolidColorBrush x:Key="StatusRed"   Color="#E04444"/>
        <SolidColorBrush x:Key="StatusAmber" Color="#E8A020"/>
        <SolidColorBrush x:Key="SafeColor"   Color="#22DD88"/>
        <SolidColorBrush x:Key="RowBg"       Color="#130F1E"/>
        <SolidColorBrush x:Key="RowBgAlt"    Color="#170D26"/>
        <SolidColorBrush x:Key="RowHov"      Color="#1F1737"/>
        <SolidColorBrush x:Key="RowSel"      Color="#372378"/>
        <SolidColorBrush x:Key="HdrBg"       Color="#0F0B18"/>
        <SolidColorBrush x:Key="GridLine"    Color="#211641"/>
        <SolidColorBrush x:Key="InputBg"     Color="#0D0A14"/>
        <SolidColorBrush x:Key="InputBd"     Color="#3A2A72"/>
        <!-- UA: Помаранчеві кольори для кнопки "Очистити технічні" / EN: Orange colors for "Clear Technical" -->
        <SolidColorBrush x:Key="OrangeBg"    Color="#3D1A00"/>
        <SolidColorBrush x:Key="OrangeBd"    Color="#FF6600"/>
        <SolidColorBrush x:Key="OrangeFg"    Color="#FFAA55"/>

        <!-- ═══════════════════════════════════════════════════════════════════
             РОЗМІРИ ШРИФТІВ / FONT SIZES
             FontBase/Sm/Tiny — для ДАНИХ у таблиці (масштабуються)
             FontUI/UILg     — для ХРОМУ програми (фіксовані)
             ═══════════════════════════════════════════════════════════════════ -->
        <sys:Double x:Key="FontBase">12</sys:Double>
        <sys:Double x:Key="FontSm">10.5</sys:Double>
        <sys:Double x:Key="FontTiny">10</sys:Double>
        <sys:Double x:Key="FontUI">11</sys:Double>
        <sys:Double x:Key="FontUILg">12</sys:Double>

        <!-- ═══════════════════════════════════════════════════════════════════
             СТИЛІ КНОПОК / BUTTON STYLES
             UA: DarkBtn/SmallBtn використовують FontUI (фіксований) —
                 щоб кнопки шапки не виповзали за межі при великому шрифті даних.
             EN: DarkBtn/SmallBtn use FontUI (fixed) —
                 so header buttons don't overflow at large data font sizes.
             ═══════════════════════════════════════════════════════════════════ -->

        <!-- Базова темна кнопка / Base dark button -->
        <Style x:Key="DarkBtn" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource BgCard}"/>
            <Setter Property="Foreground"       Value="{DynamicResource TextPrim}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource BdAcc}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="10,5"/>
            <Setter Property="FontSize"         Value="{DynamicResource FontUI}"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="{DynamicResource BgCardHov}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Акцент (фіолетовий) / Primary (purple) -->
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background"  Value="{DynamicResource AccentDark}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Безпечне збереження (зелена рамка) / Safe save (green border) -->
        <Style x:Key="SafeBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Foreground"  Value="{DynamicResource SafeColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SafeColor}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SafeColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BgBase}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Фільтр (тулбар) / Filter (toolbar) -->
        <Style x:Key="FilterBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Padding"  Value="9,4"/>
            <Setter Property="FontSize" Value="{DynamicResource FontUI}"/>
        </Style>

        <!-- Мала службова / Small utility -->
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Padding"  Value="7,3"/>
            <Setter Property="FontSize" Value="{DynamicResource FontUI}"/>
        </Style>

        <!-- UA: Помаранчева кнопка для небезпечних дій (Очистити технічні).
                 Адаптується до теми через OrangeBg/OrangeBd/OrangeFg.
             EN: Orange button for dangerous actions (Clear Technical).
                 Adapts to theme via OrangeBg/OrangeBd/OrangeFg. -->
        <Style x:Key="OrangeBtn" TargetType="Button" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background"  Value="{DynamicResource OrangeBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource OrangeBd}"/>
            <Setter Property="Foreground"  Value="{DynamicResource OrangeFg}"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource OrangeBd}"/>
                                <Setter Property="Foreground" Value="{DynamicResource BgBase}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════════════
             ПОЛЕ ВВОДУ З PLACEHOLDER / INPUT FIELD WITH PLACEHOLDER
             UA: Tag використовується як текст placeholder.
             EN: Tag property used as placeholder text.
             ═══════════════════════════════════════════════════════════════════ -->
        <Style x:Key="DarkInput" TargetType="TextBox">
            <Setter Property="Background"               Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"               Value="{DynamicResource TextPrim}"/>
            <Setter Property="CaretBrush"               Value="{DynamicResource TextPrim}"/>
            <Setter Property="BorderBrush"              Value="{DynamicResource InputBd}"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Padding"                  Value="10,5"/>
            <Setter Property="FontSize"                 Value="{DynamicResource FontUI}"/>
            <Setter Property="SelectionBrush"           Value="{DynamicResource Accent}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                <!-- UA: Placeholder — видимий лише коли поле порожнє
                                     EN: Placeholder — visible only when field is empty -->
                                <TextBlock Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource TextDim}"
                                           FontStyle="Italic" IsHitTestVisible="False"
                                           VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                           Margin="11,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text,
                                                    RelativeSource={RelativeSource TemplatedParent}}"
                                                    Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
